{
  "swagger" : "2.0",
  "info" : {
    "version" : "1.0.0",
    "title" : "swagger simple API",
    "description" : "A simple Swagger example 01"
  },
  "host" : "example.com",
  "basePath" : "/api",
  "schemes" : [ "https" ],
  "consumes" : [ "application/json" ],
  "produces" : [ "application/json" ],
  "paths" : {
    "/hello" : {
      "get" : {
        "summary" : "Returns a greeting",
        "responses" : {
          "200" : {
            "description" : "Successful response",
            "schema" : {
              "type" : "object",
              "properties" : {
                "message" : {
                  "type" : "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
